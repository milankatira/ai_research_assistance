# ── Required API keys ─────────────────────────────────────────────────────────
# Tavily web search — https://app.tavily.com
TAVILY_API_KEY=your-tavily-key-here

# No Gemini / Google key needed — the LLM runs locally via Ollama.
# Make sure Ollama is installed (https://ollama.com) and the model is pulled:
#   ollama pull gemma3
#   ollama serve

# ── Optional tuning (defaults shown) ──────────────────────────────────────────
# RESEARCHMIND_MODEL=gemma3            # any model available in your Ollama install
# RESEARCHMIND_TEMPERATURE=0
# RESEARCHMIND_MAX_RESULTS=5
# RESEARCHMIND_SCRAPE_TIMEOUT=10
# RESEARCHMIND_SCRAPE_MAX_CHARS=3000
# RESEARCHMIND_LOG_LEVEL=INFO

# Override if Ollama runs on a different host/port (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
